{{- /* Seed WSL ~/.local/share/chezmoi from Windows source, then keep it refreshed and apply from that source. */ -}}
set -euo pipefail
CHEZMOI_SRC={{ printf "%q" .wslChezmoiSource }}
dest="$HOME/.local/share/chezmoi"
if [ -d "$dest" ]; then
  echo "chezmoi source already exists at $dest; refreshing from Windows source and continuing with apply." >&2
  cp -a "$CHEZMOI_SRC"/. "$dest"/
else
  mkdir -p "$HOME/.local/share"
  cp -a "$CHEZMOI_SRC" "$dest"
fi
if [ ! -x "$HOME/.local/bin/chezmoi" ] && ! command -v chezmoi >/dev/null 2>&1; then
  curl -fsLS get.chezmoi.io -o /tmp/install-chezmoi.sh
  sh /tmp/install-chezmoi.sh -- -b "$HOME/.local/bin"
fi
PATH="$HOME/.local/bin:$PATH"
if ! WSL_DISTRO_NAME="${WSL_DISTRO_NAME:-Ubuntu}" DOTFILES_SKIP_BITWARDEN=1 "$HOME/.local/bin/chezmoi" init --apply \
    --guess-repo-url=false --source="$dest" --exclude=externals; then
  echo "Initial chezmoi init --apply failed (e.g. state DB lock). Run it manually in WSL when ready." >&2
  exit 1
fi
