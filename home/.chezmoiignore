# .chezmoiignore — source-dir-only files that should not be applied to ~/
Brewfile.ignore
Chocofile.ignore

{{ if eq .chezmoi.os "windows" }}
# Unix-only targets — not applicable on Windows
.zshenv
.profile
.config/zsh
.config/finicky.js
.gnupg
.scripts
.local/share/opencode-shims
{{ end }}

{{ if ne .chezmoi.os "windows" }}
# Windows-only targets — not applicable on Unix
.config/wezterm
.config/yasb
.config/oh-my-posh
.glzr
AppData
Documents
{{ end }}

{{ if ne .chezmoi.os "darwin" }}
# macOS-only targets — not applicable on non-macOS
.config/tmux
.config/ghostty
.config/finicky.js
Library
{{ end }}

{{ if not .codespaces }}
# Codespaces-only targets — not applicable outside Codespaces
.gitconfig.overrides
{{ end }}
