#!/usr/bin/env bash
# brew-review — interactive Homebrew drift review
#
# Compares what is actually installed (brew bundle dump) against the
# declared Brewfile in the chezmoi source directory. Prompts for each
# package that is installed but not declared.
#
# Usage: brew-review [--brewfile <path>] [--ignore <path>]
#
# Exits silently if there is no drift or if stdin is not a tty.

set -uo pipefail

export HOMEBREW_NO_AUTO_UPDATE=1

# Skip entirely when not interactive
if [ ! -t 0 ]; then
	exit 0
fi

# Resolve paths — prefer env vars set by chezmoi, fall back to defaults
CHEZMOI_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$(chezmoi source-path 2>/dev/null || echo "$HOME/.local/share/chezmoi")}"
BREWFILE="${1:-$CHEZMOI_SOURCE_DIR/Brewfile}"
IGNOREFILE="${2:-$CHEZMOI_SOURCE_DIR/Brewfile.ignore}"
BREWFILE_TMPL="$CHEZMOI_SOURCE_DIR/Brewfile.tmpl"
BREW_DATA_DIR="$CHEZMOI_SOURCE_DIR/.chezmoidata/brew"

if [ ! -f "$BREWFILE" ]; then
	echo "brew-review: Brewfile not found at $BREWFILE" >&2
	exit 1
fi

if [ ! -f "$BREWFILE_TMPL" ] || [ ! -d "$BREW_DATA_DIR" ]; then
	echo "brew-review: Brew overlay source files not found under $BREW_DATA_DIR" >&2
	exit 1
fi

# Extract base keys from a Brewfile-format file (type + quoted name only)
# e.g. 'cask "1password" if OS.mac? # work' -> 'cask "1password"'
_extract_keys() {
	grep -v '^\s*#' "$1" 2>/dev/null |
		grep -oE '(brew|cask|mas|tap|whalebrew)\s+"[^"]+"' ||
		true
}

_load_overlay_map() {
	local -a files=()
	shopt -s nullglob
	files=("$BREW_DATA_DIR"/*.yaml)
	shopt -u nullglob
	if [ ${#files[@]} -eq 0 ]; then
		return 1
	fi

	while IFS=$'\t' read -r overlay_id overlay_file; do
		[ -z "$overlay_id" ] && continue
		[ "$overlay_id" = "base" ] && continue
		OVERLAY_IDS+=("$overlay_id")
		OVERLAY_FILES+=("$overlay_file")
	done < <(
		ruby -ryaml -e '
			ARGV.sort.each do |file|
			  data = YAML.load_file(file) || {}
			  overlays = data.dig("brew", "overlays")
			  next unless overlays.is_a?(Hash)
			  overlays.each_key { |id| puts "#{id}\t#{file}" }
			end
		' "${files[@]}"
	)

	[ ${#OVERLAY_IDS[@]} -gt 0 ]
}

_overlay_file_for_id() {
	local overlay_id="$1"
	local i
	for ((i = 0; i < ${#OVERLAY_IDS[@]}; i++)); do
		if [ "${OVERLAY_IDS[$i]}" = "$overlay_id" ]; then
			printf '%s\n' "${OVERLAY_FILES[$i]}"
			return 0
		fi
	done
	return 1
}

_choose_overlay_id() {
	local default_overlay="$1"
	local i
	echo "  Select overlay target:" >&2
	for ((i = 0; i < ${#OVERLAY_IDS[@]}; i++)); do
		printf "    [%d] %s\n" "$((i + 1))" "${OVERLAY_IDS[$i]}" >&2
	done

	local default_index=1
	for ((i = 0; i < ${#OVERLAY_IDS[@]}; i++)); do
		if [ "${OVERLAY_IDS[$i]}" = "$default_overlay" ]; then
			default_index=$((i + 1))
			break
		fi
	done

	while true; do
		printf "  Overlay number [%d]: " "$default_index" >&2
		read -r overlay_choice </dev/tty
		[ -z "$overlay_choice" ] && overlay_choice="$default_index"
		if [[ "$overlay_choice" =~ ^[0-9]+$ ]] && [ "$overlay_choice" -ge 1 ] && [ "$overlay_choice" -le "${#OVERLAY_IDS[@]}" ]; then
			printf '%s\n' "${OVERLAY_IDS[$((overlay_choice - 1))]}"
			return 0
		fi
		echo "  Please enter a valid overlay number." >&2
	done
}

_append_package_to_overlay() {
	local overlay_id="$1"
	local pkg_type="$2"
	local pkg_name="$3"
	local mas_id="${4:-}"
	local overlay_file
	overlay_file="$(_overlay_file_for_id "$overlay_id")" || return 1

	{
		echo ""
		echo "        - type: $pkg_type"
		echo "          name: $pkg_name"
		if [ "$pkg_type" = "cask" ]; then
			echo "          conditions:"
			echo "            - { kind: os, op: is, value: mac }"
		elif [ "$pkg_type" = "mas" ]; then
			echo "          masId: $mas_id"
			echo "          conditions:"
			echo "            - { kind: os, op: is, value: mac }"
			echo "            - { kind: tty, op: is, value: true }"
		fi
	} >>"$overlay_file"
}

_rerender_brewfile() {
	chezmoi execute-template --file "$BREWFILE_TMPL" >"$BREWFILE"
}

# Extract declared keys from Brewfile directly (preserves type prefix; strips conditionals/comments)
declared_keys=$(_extract_keys "$BREWFILE")

# Get installed set via brew bundle dump
dump_tmp=$(mktemp)
trap 'rm -f "$dump_tmp"' EXIT
brew bundle dump --file="$dump_tmp" --force --quiet 2>/dev/null
installed_keys=$(_extract_keys "$dump_tmp")

# Get ignore set
ignore_keys=""
if [ -f "$IGNOREFILE" ]; then
	ignore_keys=$(_extract_keys "$IGNOREFILE")
fi

# Find extras: installed but not in Brewfile and not in ignore
extras=()
while IFS= read -r key; do
	[ -z "$key" ] && continue
	if ! echo "$declared_keys" | grep -qF "$key"; then
		if ! echo "$ignore_keys" | grep -qF "$key"; then
			extras+=("$key")
		fi
	fi
done <<<"$installed_keys"

if [ ${#extras[@]} -eq 0 ]; then
	exit 0
fi

echo ""
echo "==> Homebrew drift review"
echo ""

# Prompt for extras
if [ ${#extras[@]} -gt 0 ]; then
	OVERLAY_IDS=()
	OVERLAY_FILES=()
	if ! _load_overlay_map; then
		echo "brew-review: no non-base brew overlays found in $BREW_DATA_DIR" >&2
		exit 1
	fi
	DEFAULT_OVERLAY="${OVERLAY_IDS[0]}"

	echo "The following packages are installed but not in Brewfile:"
	echo ""
	for key in "${extras[@]}"; do
		pkg=$(echo "$key" | grep -oE '"[^"]+"' | tr -d '"')
		type=$(echo "$key" | awk '{print $1}')

		# Skip if already gone (e.g. removed as a tap dependency earlier in this run)
		case "$type" in
		tap)
			brew tap-info "$pkg" &>/dev/null || {
				echo "  (skipping $key — already removed)"
				echo ""
				continue
			}
			;;
		cask)
			brew list --cask "$pkg" &>/dev/null || {
				echo "  (skipping $key — already removed)"
				echo ""
				continue
			}
			;;
		mas)
			# mas apps are not formulae/casks and require special handling later.
			:
			;;
		*)
			brew list --formula "$pkg" &>/dev/null || {
				echo "  (skipping $key — already removed)"
				echo ""
				continue
			}
			;;
		esac

		# For taps, show contents upfront as context before prompting
		if [ "$type" = "tap" ]; then
			tap_info=$(brew tap-info --json "$pkg" 2>/dev/null)
			tap_formulae=$(echo "$tap_info" | python3 -c "import json,sys; t=json.load(sys.stdin)[0]; [print(f) for f in t.get('formula_names',[])]" 2>/dev/null | while IFS= read -r f; do brew list --formula "$f" &>/dev/null && echo "$f"; done || true)
			tap_casks=$(echo "$tap_info" | python3 -c "import json,sys; t=json.load(sys.stdin)[0]; [print(c) for c in t.get('cask_tokens',[])]" 2>/dev/null | while IFS= read -r c; do brew list --cask "$c" &>/dev/null && echo "$c"; done || true)
			printf "  %s" "$key"
			if [ -n "$tap_formulae" ] || [ -n "$tap_casks" ]; then
				echo " (contains installed packages:"
				if [ -n "$tap_formulae" ]; then
					while IFS= read -r formula; do
						printf "     formula: %s\n" "$formula"
					done <<<"$tap_formulae"
				fi
				if [ -n "$tap_casks" ]; then
					while IFS= read -r cask; do
						printf "     cask: %s\n" "$cask"
					done <<<"$tap_casks"
				fi
				printf "  )"
			fi
			echo ""
		else
			printf "  %s\n" "$key"
		fi

		while true; do
			printf "  [a]dd to brew overlay / [r]emove / [i]gnore permanently / [s]kip: "
			read -r reply </dev/tty
			case "$reply" in
			a | A)
				selected_overlay="$(_choose_overlay_id "$DEFAULT_OVERLAY")"
				DEFAULT_OVERLAY="$selected_overlay"
				if [ "$type" = "mas" ]; then
					printf "  Enter MAS app id for %s: " "$pkg"
					read -r mas_id </dev/tty
					if ! [[ "$mas_id" =~ ^[0-9]+$ ]]; then
						echo "  -> Invalid MAS id, skipping"
						break
					fi
					_append_package_to_overlay "$selected_overlay" "$type" "$pkg" "$mas_id"
				else
					_append_package_to_overlay "$selected_overlay" "$type" "$pkg"
				fi
				if _rerender_brewfile; then
					echo "  -> Added $key to overlay '$selected_overlay' and regenerated Brewfile"
				else
					echo "  -> Added $key to overlay '$selected_overlay', but failed to regenerate Brewfile" >&2
				fi
				break
				;;
			r | R)
				if [ "$type" = "tap" ]; then
					# Uninstall installed formulae/casks from the tap before untapping
					if [ -n "${tap_formulae:-}" ]; then
						while IFS= read -r f; do
							[ -z "$f" ] && continue
							echo "  -> Uninstalling formula: $f"
							brew uninstall "$f"
						done <<<"$tap_formulae"
					fi
					if [ -n "${tap_casks:-}" ]; then
						while IFS= read -r c; do
							[ -z "$c" ] && continue
							echo "  -> Uninstalling cask: $c"
							brew uninstall --cask "$c"
						done <<<"$tap_casks"
					fi
					brew untap --force "$pkg"
				elif [ "$type" = "cask" ]; then
					brew uninstall --cask "$pkg"
				else
					brew uninstall "$pkg"
				fi
				echo "  -> Removed $pkg"
				break
				;;
			i | I)
				echo "$key" >>"$IGNOREFILE"
				echo "  -> Added to $IGNOREFILE"
				break
				;;
			s | S | "")
				echo "  -> Skipped"
				break
				;;
			*)
				echo "  Please enter a, r, i, or s."
				;;
			esac
		done
		echo ""
	done
fi
