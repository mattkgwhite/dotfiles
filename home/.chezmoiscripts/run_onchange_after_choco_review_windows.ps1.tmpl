{{- if eq .chezmoi.os "windows" -}}
# Run interactive Chocolatey drift review after Chocolatey overlay updates.
# Exits silently when no bash runtime is available.
#
# Chocolatey overlay hash (triggers re-run when overlay data changes):
# {{ .chocolatey.overlays | toJson | sha256sum }}
# Ignore file hash:
# {{ include "Chocofile.ignore" | sha256sum }}

$ErrorActionPreference = "Stop"

if (-not [Environment]::UserInteractive) {
    exit 0
}

$bashCandidates = @()
$bashCmd = Get-Command bash -ErrorAction SilentlyContinue
if ($bashCmd) {
    $bashCandidates += $bashCmd.Source
}

$programFiles = @($env:ProgramFiles, ${env:ProgramFiles(x86)}) | Where-Object { $_ }
foreach ($root in $programFiles) {
    $bashCandidates += (Join-Path $root "Git\bin\bash.exe")
    $bashCandidates += (Join-Path $root "Git\usr\bin\bash.exe")
}

$bashPath = $bashCandidates |
    Where-Object { $_ -and (Test-Path $_) } |
    Select-Object -First 1

if (-not $bashPath) {
    exit 0
}

$chezmoiSourceDir = $env:CHEZMOI_SOURCE_DIR
if (-not $chezmoiSourceDir) {
    $chezmoiSourceDir = (chezmoi source-path).Trim()
}

$chocoReview = Join-Path $chezmoiSourceDir "dot_scripts/choco-review"
if (-not (Test-Path $chocoReview)) {
    exit 0
}

& $bashPath $chocoReview
if ($LASTEXITCODE -ne 0) {
    Write-Warning "choco-review exited with code $LASTEXITCODE"
}
{{- end }}
