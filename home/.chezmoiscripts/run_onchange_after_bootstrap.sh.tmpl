{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash

# -e: exit on error
# -u: exit on unset variables
set -eu
{{ if .codespaces -}}
set -x
{{- end }}

{{ if .codespaces -}}
cat <<EOF >"$HOME/.gitconfig.overrides"
[user]
	name = {{ .profile.codespaces.gitName }}
[gpg]
	program = /.codespaces/bin/gh-gpgsign
EOF
{{ end -}}

{{ if eq .chezmoi.os "linux" -}}
PKGS="build-essential procps curl file git libffi-dev libyaml-dev zlib1g-dev"
if ! dpkg -s $PKGS &>/dev/null; then
  sudo apt update -q
  sudo apt install -yq $PKGS
fi
{{ end -}}

{{- if eq .chezmoi.os "darwin" "linux" -}}
if ! command -v brew 2>&1 >/dev/null; then
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Ensure this process sees Homebrew-installed binaries (nvim, zsh, etc.).
if command -v brew 2>&1 >/dev/null; then
  eval "$(brew shellenv)"
else
  export PATH="$PATH:$HOME/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/bin:/opt/homebrew/bin"
  if command -v brew 2>&1 >/dev/null; then
    eval "$(brew shellenv)"
  fi
fi

NVIM_PRE_INSTALLED=""
if command -v nvim 2>&1 >/dev/null; then
  NVIM_PRE_INSTALLED=1
fi

export HOMEBREW_CASK_OPTS="--require-sha"
export HOMEBREW_NO_AUTO_UPDATE=1

BREWFILE_RENDERED="$(mktemp)"
trap 'rm -f "$BREWFILE_RENDERED"' EXIT INT TERM
SOURCE_HINT="${CHEZMOI_SOURCE_DIR:-}"
SOURCE_PATH="$(chezmoi source-path)"
SOURCE_DIR=""
for candidate in "$SOURCE_HINT" "$SOURCE_PATH" "$SOURCE_PATH/home"; do
  if [ -z "$candidate" ] || [ ! -f "$candidate/Brewfile.tmpl" ]; then
    continue
  fi
  if chezmoi --source "$candidate" data | rg '"brew"' >/dev/null 2>&1; then
    SOURCE_DIR="$candidate"
    break
  fi
done

if [ -z "$SOURCE_DIR" ]; then
  echo "Cannot resolve chezmoi source for Brewfile rendering (hint=$SOURCE_HINT source-path=$SOURCE_PATH)." >&2
  exit 1
fi

chezmoi --source "$SOURCE_DIR" execute-template --file "$SOURCE_DIR/Brewfile.tmpl" >"$BREWFILE_RENDERED"
if ! rg '^brew "neovim"' "$BREWFILE_RENDERED" >/dev/null 2>&1; then
  echo "Rendered Brewfile is missing neovim entry (SOURCE_DIR=$SOURCE_DIR)." >&2
  exit 1
fi

if [ -n "${CI:-}" ]; then
  export HOMEBREW_CI="${HOMEBREW_CI:-1}"
fi

if [ -n "${CODESPACES:-}" ]; then
  CODESPACES=1 brew bundle -q --file="$BREWFILE_RENDERED" || true
elif [ -n "${CI:-}" ] || [ -n "${HOMEBREW_CI:-}" ]; then
  CI=1 HOMEBREW_CI=1 brew bundle -q --no-upgrade --file="$BREWFILE_RENDERED"
elif [ -n "${PRIVATE:-}" ]; then
  PRIVATE=1 brew bundle -q --file="$BREWFILE_RENDERED"
else
  brew bundle -q --file="$BREWFILE_RENDERED"
fi

# Prewarm antidote plugin cache so the first shell launch doesn't clone everything
zsh -c '
  zstyle ":antidote:bundle" use-friendly-names yes
  source "$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
  antidote bundle < "${ZDOTDIR:-$HOME/.config/zsh}/.zplugins" > /dev/null
' || true

{{- if not .codespaces }}
mise trust
mise install || true

if [ -z "$NVIM_PRE_INSTALLED" ]; then
  if ! brew list --versions neovim >/dev/null 2>&1; then
    echo "neovim is not installed after brew bundle." >&2
    exit 1
  fi
  NVIM_BIN="$(brew --prefix)/bin/nvim"
  if [ ! -x "$NVIM_BIN" ]; then
    echo "neovim binary not found at $NVIM_BIN after brew bundle." >&2
    exit 1
  fi
  "$NVIM_BIN" --headless "+Lazy! sync" +qa
fi

BREW_ZSH="$(brew --prefix)/bin/zsh"
if [ -x "$BREW_ZSH" ] && [ "$SHELL" != "$BREW_ZSH" ]; then
  if ! grep -qxF "$BREW_ZSH" /etc/shells; then
    echo "$BREW_ZSH" | sudo tee -a /etc/shells >/dev/null
  fi
  sudo chsh -s "$BREW_ZSH" "$(whoami)"
fi
{{- end }}

# Reload all running zsh sessions so they pick up the updated config
{{- if .codespaces }}
pkill -HUP -u "$(whoami)" zsh || true
{{- end }}
{{ end -}}
{{- end }}
