{{- if eq .chezmoi.os "windows" -}}
  {{- $wslWin := fromJson (includeTemplate ".chezmoitemplates/wsl-windows-script-context.json.tmpl" . | trim) -}}
  {{- $wslLinuxUser := index $wslWin "linuxUser" -}}
  {{- $wslChezmoiSource := index $wslWin "chezmoiSourceMount" -}}
$ErrorActionPreference = "Stop"
{{ includeTemplate ".chezmoitemplates/windows-elevation.ps1.tmpl" . }}

$wslCmd = Get-Command wsl -ErrorAction SilentlyContinue
if ($wslCmd) {
    $distros = wsl --list --quiet 2>$null
    if ($LASTEXITCODE -eq 0 -and $distros -contains "Ubuntu") {
        Write-Host "WSL Ubuntu already installed; skipping provisioning."
        return
    }
}

$elevatedScript = {
    $ErrorActionPreference = "Stop"

    if (-not (Get-Command wsl -ErrorAction SilentlyContinue)) {
        Write-Host "Installing WSL..."
        wsl --install --no-distribution
        if ($LASTEXITCODE -ne 0) {
            throw "WSL install command failed (exit code $LASTEXITCODE). Reboot Windows, then run 'chezmoi apply' again."
        }
        Write-Host "WSL installed. A reboot may be required before WSL is available."
    }

    if (-not (Get-Command wsl -ErrorAction SilentlyContinue)) {
        throw "WSL is not available yet. Reboot Windows, then run 'chezmoi apply' again."
    }

    $distros = wsl --list --quiet 2>$null
    if ($distros -contains "Ubuntu") {
        Write-Host "WSL Ubuntu already installed; skipping provisioning."
        return
    }

    $wslUser = '{{ $wslLinuxUser }}'
    $cloudInitDir = "$env:USERPROFILE\.cloud-init"
    if (-not (Test-Path $cloudInitDir)) {
        New-Item -ItemType Directory -Path $cloudInitDir | Out-Null
    }
    $cloudConfig = @"
{{ .windowsWsl.ubuntuCloudInitUserData | replace "__WSL_CHEZMOI_SOURCE__" $wslChezmoiSource | replace "__WSL_USER__" $wslLinuxUser }}
"@
    [System.IO.File]::WriteAllText("$cloudInitDir\Ubuntu.user-data", $cloudConfig)

    Write-Host "Installing Ubuntu WSL distribution..."
    wsl --install Ubuntu --no-launch
    if ($LASTEXITCODE -ne 0) {
        throw "Ubuntu installation failed (exit code $LASTEXITCODE). Reboot Windows, then run 'chezmoi apply' again."
    }

    Write-Host "Launching Ubuntu for cloud-init provisioning..."
    wsl -d Ubuntu -- true
    $prevLine = ""
    $deadline = (Get-Date).AddMinutes(10)
    do {
        Start-Sleep -Seconds 5
        $status = (wsl -d Ubuntu -- cloud-init status 2>$null) -replace '^\s+',''
        $tail = wsl -d Ubuntu -- bash -c "tail -1 /var/log/cloud-init-output.log 2>/dev/null" 2>$null
        if ($tail -and $tail -ne $prevLine) {
            Write-Host "  [$status] $tail"
            $prevLine = $tail
        }
        if ((Get-Date) -ge $deadline -and $status -match "running") {
            throw "cloud-init still running after 10 minutes. Let it finish, then rerun 'chezmoi apply'."
        }
    } while ($status -match "running")

    if ($status -match "error") {
        throw "cloud-init finished with errors. Run 'wsl -d Ubuntu -- cat /var/log/cloud-init.log' for details."
    } else {
        Write-Host "WSL provisioning complete." -ForegroundColor Green
    }
}

Invoke-ElevatedWithLog `
    -Name "wsl-ensure" `
    -ScriptBlock $elevatedScript `
    -StatusMessage "Elevating for WSL provisioning..." `
    -FailureMessage "Elevated WSL provisioning failed"
  {{- end }}
