{{- $chocoPackages := list -}}
{{- if and (hasKey . "chocolatey") (hasKey .chocolatey "overlays") -}}
  {{- range $name := keys .chocolatey.overlays | sortAlpha -}}
    {{- $ov := index $.chocolatey.overlays $name -}}
    {{- $chocoPackages = concat $chocoPackages (default (list) $ov.packages) -}}
  {{- end -}}
{{- end -}}
{{- $wingetPackages := list -}}
{{- if and (hasKey . "winget") (hasKey .winget "overlays") -}}
  {{- range $name := keys .winget.overlays | sortAlpha -}}
    {{- $ov := index $.winget.overlays $name -}}
    {{- $wingetPackages = concat $wingetPackages (default (list) $ov.packages) -}}
  {{- end -}}
{{- end -}}
{{- if eq .chezmoi.os "windows" -}}
  {{- $wslWin := fromJson (includeTemplate ".chezmoitemplates/wsl-windows-script-context.json.tmpl" . | trim) -}}
  {{- $wslLinuxUser := index $wslWin "linuxUser" -}}
  {{- $wslChezmoiSource := index $wslWin "chezmoiSourceMount" -}}
# Chocolatey package list hash (triggers re-run when this list changes):
# {{ join " " $chocoPackages | sha256sum }}
# Winget package list hash (triggers re-run when this list changes):
# {{ join " " $wingetPackages | sha256sum }}

$ErrorActionPreference = "Stop"
{{ includeTemplate ".chezmoitemplates/windows-elevation.ps1.tmpl" . }}

# --- Elevated block: Chocolatey packages + WSL provisioning ---
$elevatedScript = {
    $ErrorActionPreference = "Stop"
    function Assert-LastExitCode {
        param(
            [Parameter(Mandatory = $true)]
            [string]$CommandName
        )
        if ($LASTEXITCODE -ne 0) {
            throw "$CommandName failed with exit code $LASTEXITCODE."
        }
    }

    if (-not (Get-Command choco -ErrorAction SilentlyContinue)) {
        Write-Host "Installing Chocolatey..."
        Set-ExecutionPolicy Bypass -Scope Process -Force
        [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072
        Invoke-Expression ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))
        $env:PATH = "$env:ALLUSERSPROFILE\chocolatey\bin;$env:PATH"
    }

    Write-Host "Installing Chocolatey packages..."
    choco install {{ join " " $chocoPackages }} -y --no-progress
    Assert-LastExitCode "choco install"

    $wingetPackages = "{{ join " " $wingetPackages }}".Split(" ", [System.StringSplitOptions]::RemoveEmptyEntries)
    foreach ($wingetPackage in $wingetPackages) {
        $existing = winget list --id $wingetPackage --exact --accept-source-agreements 2>$null | Out-String
        if ($existing -match [Regex]::Escape($wingetPackage)) {
            Write-Host "Winget package already installed: $wingetPackage"
            continue
        }

        Write-Host "Installing Winget package: $wingetPackage"
        winget install --id $wingetPackage --exact --silent --accept-package-agreements --accept-source-agreements
        Assert-LastExitCode "winget install ($wingetPackage)"
    }

    # --- WSL ---
    if (-not (Get-Command wsl -ErrorAction SilentlyContinue)) {
        Write-Host "Installing WSL..."
        wsl --install --no-distribution
        Assert-LastExitCode "wsl --install --no-distribution"
        Write-Host "WSL installed. A reboot may be required before WSL is available."
    }

    if (-not (Get-Command wsl -ErrorAction SilentlyContinue)) {
        throw "WSL command is not available after installation."
    }

    Write-Host "Updating WSL to latest pre-release..."
    wsl --update --pre-release
    Assert-LastExitCode "wsl --update --pre-release"

    if (Get-Command wsl -ErrorAction SilentlyContinue) {
        $distros = wsl --list --quiet 2>$null
        if ($distros -notcontains "Ubuntu") {
            $wslUser = '{{ $wslLinuxUser }}'
            $cloudInitDir = "$env:USERPROFILE\.cloud-init"
            if (-not (Test-Path $cloudInitDir)) {
                New-Item -ItemType Directory -Path $cloudInitDir | Out-Null
            }
            $cloudConfig = @"
{{ .windowsWsl.ubuntuCloudInitUserData | replace "__WSL_CHEZMOI_SOURCE__" $wslChezmoiSource | replace "__WSL_USER__" $wslLinuxUser }}
"@
            [System.IO.File]::WriteAllText("$cloudInitDir\Ubuntu.user-data", $cloudConfig)

            Write-Host "Installing Ubuntu WSL distribution (cloud-init will provision user '$wslUser')..."
            wsl --install Ubuntu --no-launch
            Assert-LastExitCode "wsl --install Ubuntu --no-launch"

            Write-Host "Launching Ubuntu for cloud-init provisioning..."
            $prevLine = ""
            do {
                Start-Sleep -Seconds 5
                $status = (wsl -d Ubuntu -- cloud-init status 2>$null) -replace '^\s+',''
                $tail = wsl -d Ubuntu -- bash -c "tail -1 /var/log/cloud-init-output.log 2>/dev/null" 2>$null
                if ($tail -and $tail -ne $prevLine) {
                    Write-Host "  [$status] $tail"
                    $prevLine = $tail
                }
            } while ($status -match "running")

            if ($status -match "error") {
                throw "cloud-init finished with errors. Run 'wsl -d Ubuntu -- cat /var/log/cloud-init.log' for details."
            } else {
                Write-Host "WSL provisioning complete." -ForegroundColor Green
            }
        } else {
            $wslUser = '{{ $wslLinuxUser }}'
            $wslUserExists = (wsl -d Ubuntu -- bash -lc "id -u $wslUser >/dev/null 2>&1 && echo yes || echo no" 2>$null) -match "yes"
            if (-not $wslUserExists) {
                throw "WSL user '$wslUser' is missing in Ubuntu. Reprovision with: wsl --unregister Ubuntu; chezmoi apply."
            }

            # Existing Ubuntu only (fresh installs get [user]/default from cloud-init). Align default login with profile.windows.wslUser.
            wsl -d Ubuntu -- bash -lc @"
if ! grep -q '^\[user\]' /etc/wsl.conf 2>/dev/null; then
  printf '\n[user]\ndefault=$wslUser\n' | sudo tee -a /etc/wsl.conf >/dev/null
elif ! grep -q '^default=$wslUser$' /etc/wsl.conf 2>/dev/null; then
  sudo sed -i '/^\[user\]/,/^\[/ s/^default=.*/default=$wslUser/' /etc/wsl.conf
fi
"@
            Assert-LastExitCode "Update /etc/wsl.conf user default"
            if ($wslUserExists) {
                Write-Host "WSL default user may still be root until you run 'wsl --shutdown' once; using --user $wslUser for dotfiles update." -ForegroundColor DarkGray
            }

            Write-Host "Updating dotfiles in WSL..."
            # Single-quoted here-string: bash expands $HOME; elevated ScriptBlock does not parse $(...) as PowerShell.
            $wslUpdateBash = @'
{{ includeTemplate ".chezmoitemplates/wsl-update-dotfiles-bash.sh.tmpl" (dict "wslChezmoiSource" $wslChezmoiSource) }}
'@
            if ($wslUserExists) {
                $wslUpdateBash | wsl -d Ubuntu --user $wslUser -- bash -lc "tr -d '\r' | bash -s"
            } else {
                Write-Host "Running WSL update as default user (root); dotfiles copy will live under /root until user '$wslUser' exists and you re-apply." -ForegroundColor Yellow
                $wslUpdateBash | wsl -d Ubuntu -- bash -lc "tr -d '\r' | bash -s"
            }
            Assert-LastExitCode "WSL dotfiles update"
        }
    }
}

Invoke-ElevatedWithLog `
    -Name "bootstrap" `
    -ScriptBlock $elevatedScript `
    -StatusMessage "Elevating for package installation and WSL provisioning..."

# Refresh PATH so newly installed tools are available
$env:PATH = [System.Environment]::GetEnvironmentVariable("PATH", "Machine") + ";" + [System.Environment]::GetEnvironmentVariable("PATH", "User")

# Set XDG_CONFIG_HOME so XDG-aware tools (nvim, etc.) find configs at ~/.config
$xdgTarget = "$env:USERPROFILE\.config"
[System.Environment]::SetEnvironmentVariable("XDG_CONFIG_HOME", $xdgTarget, "User")
$env:XDG_CONFIG_HOME = $xdgTarget

# Install mise-managed tools (does not require elevation)
if (Get-Command mise -ErrorAction SilentlyContinue) {
    Write-Host "Running mise install..."
    mise trust
    mise install
    if ($LASTEXITCODE -ne 0) {
        throw "mise install failed (exit code $LASTEXITCODE)."
    }
}

# Sync Neovim plugins
if (Get-Command nvim -ErrorAction SilentlyContinue) {
    Write-Host "Syncing Neovim plugins..."
    nvim --headless "+Lazy! sync" +qa
    if ($LASTEXITCODE -ne 0) {
        throw "Neovim plugin sync failed (exit code $LASTEXITCODE)."
    }
}

# Configure GlazeWM to autostart at Windows login and start it now.
$glazeCmd = Get-Command glazewm.exe -ErrorAction SilentlyContinue
if ($glazeCmd) {
    $runKeyPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run"
    if (-not (Test-Path $runKeyPath)) {
        New-Item -Path $runKeyPath -Force | Out-Null
    }

    $glazeRunValue = '"' + $glazeCmd.Source + '" start'
    $currentGlazeRunValue = (Get-ItemProperty -Path $runKeyPath -Name "GlazeWM" -ErrorAction SilentlyContinue).GlazeWM
    if ($currentGlazeRunValue -ne $glazeRunValue) {
        Set-ItemProperty -Path $runKeyPath -Name "GlazeWM" -Value $glazeRunValue
        Write-Host "Configured GlazeWM autostart."
    } else {
        Write-Host "GlazeWM autostart already configured."
    }

    if (-not (Get-Process -Name "glazewm" -ErrorAction SilentlyContinue)) {
        Write-Host "Starting GlazeWM..."
        Start-Process -FilePath $glazeCmd.Source -ArgumentList "start"
    } else {
        Write-Host "GlazeWM is already running."
    }
}

# Configure YASB to autostart at Windows login and start it now.
$yasbCmd = Get-Command yasb -ErrorAction SilentlyContinue
if ($yasbCmd) {
    $runKeyPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run"
    if (-not (Test-Path $runKeyPath)) {
        New-Item -Path $runKeyPath -Force | Out-Null
    }

    $yasbRunValue = '"' + $yasbCmd.Source + '"'
    $currentYasbRunValue = (Get-ItemProperty -Path $runKeyPath -Name "YASB" -ErrorAction SilentlyContinue).YASB
    if ($currentYasbRunValue -ne $yasbRunValue) {
        Set-ItemProperty -Path $runKeyPath -Name "YASB" -Value $yasbRunValue
        Write-Host "Configured YASB autostart."
    } else {
        Write-Host "YASB autostart already configured."
    }

    if (-not (Get-Process -Name "yasb" -ErrorAction SilentlyContinue)) {
        Write-Host "Starting YASB..."
        Start-Process -FilePath $yasbCmd.Source
    } else {
        Write-Host "YASB is already running."
    }
}
{{- end }}
