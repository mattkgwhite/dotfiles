{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash

# Re-runs when .zplugins changes (antidote plugin layout may change):
# {{ include "dot_config/zsh/dot_zplugins.tmpl" | sha256sum }}

set -eu

{{ if not .codespaces -}}
if command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv 2>/dev/null)" || true
else
  for brew_bin in "$HOME/.linuxbrew/bin/brew" "/home/linuxbrew/.linuxbrew/bin/brew" "/opt/homebrew/bin/brew" "/usr/local/bin/brew"; do
    if [ -x "$brew_bin" ]; then
      eval "$("$brew_bin" shellenv 2>/dev/null)" || true
      break
    fi
  done
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "brew is required for tmux symlink setup." >&2
  exit 1
fi

if ! command -v zsh >/dev/null 2>&1; then
  echo "zsh is required for tmux symlink setup." >&2
  exit 1
fi

if [ ! -f "$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh" ]; then
  echo "antidote is required for tmux symlink setup." >&2
  exit 1
fi

ANTIDOTE_HOME="$(zsh -c '
  source "$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
  antidote home
')"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
mkdir -p "$XDG_CONFIG_HOME/tmux"

ln -sf "$ANTIDOTE_HOME/gpakosz/.tmux/.tmux.conf" "$XDG_CONFIG_HOME/tmux/tmux.conf"
ln -sf "$ANTIDOTE_HOME/tmux-plugins" "$XDG_CONFIG_HOME/tmux/tmux.plugins"
{{ end -}}
{{- end }}
