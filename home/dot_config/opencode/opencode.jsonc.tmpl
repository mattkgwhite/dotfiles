{
  "$schema": "https://opencode.ai/config.json",
  // User preferences (override in project opencode.json if needed)
  "autoupdate": true,

  // GitHub Copilot: run /connect and select "GitHub Copilot", then sign in at github.com/login/device
  "model": "github-copilot/claude-sonnet-4.6",

  "permission": {
    // Require approval before running any shell command (with specific exceptions)
    "bash": {
      "*": "ask",
      // Chezmoi
      "chezmoi apply": "allow",
      "chezmoi apply *": "allow",
      // Shell and environment inspection
      "echo": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "type *": "allow",
      "command -v *": "allow",
      "uname": "allow",
      "uname *": "allow",
      "env": "allow",
      "printenv": "allow",
      "printenv *": "allow",
      "locale": "allow",
      "locale *": "allow",
      "id": "allow",
      "whoami": "allow",
      "groups": "allow",
      "date": "allow",
      "date *": "allow",
      // File and text inspection
      "ls": "allow",
      "ls *": "allow",
      "find *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "du *": "allow",
      "du -s *": "allow",
      "du -h *": "allow",
      "wc *": "allow",
      "head *": "allow",
      "tail *": "allow",
      // GitHub CLI
      "gh run view *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "egrep *": "allow",
      "fgrep *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "jq *": "allow",
      "column *": "allow",
      "nl *": "allow",
      "base64 *": "allow",
      "xxd *": "allow",
      "strings *": "allow",
      "md5sum *": "allow",
      "sha1sum *": "allow",
      "sha256sum *": "allow",
      "shasum *": "allow",
      "cksum *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      // System and process inspection
      "ps": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      "df": "allow",
      "df *": "allow",
      "uptime": "allow",
      "uptime *": "allow",
      "lsof *": "allow",
      // Git inspection
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git remote -v": "allow",
      "git remote show *": "allow",
      "git rev-parse *": "allow",
      "git describe *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git grep *": "allow",
      "git blame *": "allow",
      // Network inspection
      "ping *": "allow",
      "nslookup *": "allow",
      "dig *": "allow",
      "host *": "allow",
      "netstat": "allow",
      "netstat *": "allow",
      "ifconfig": "allow",
      "ifconfig *": "allow",
      // Kubernetes and containers
      "kubectl config get-contexts": "allow",
      "kubectl config current-context": "allow",
      "kubectl get *": "allow",
      "docker ps": "allow",
      "docker ps *": "allow",
      "docker images": "allow",
      "docker images *": "allow"
    },

    // Allow reads and edits to the chezmoi source tree (global memory lives there)
    "external_directory": {
      "~/.local/share/chezmoi/**": "allow",
      "/tmp/**": "allow",
      "{{ .chezmoi.homeDir }}/AppData/Local/Temp/**": "allow"
    }
{{- if not .private }},

    // Require approval before any Atlassian MCP tool is invoked
    "atlassian_*": "ask",

    // Require approval before any sooperset/mcp-atlassian tool is invoked
    "mcp-atlassian_*": "ask",

    // Read-only Atlassian tools (only read:* scopes) — allow without prompting
    "atlassian_get*": "allow",
    "atlassian_search*": "allow",
    // Outliers with read-only scopes that don't match above patterns
    "atlassian_atlassianUserInfo": "allow",
    "atlassian_fetch": "allow",
    "atlassian_lookupJiraAccountId": "allow",

    // Read-only mcp-atlassian (sooperset) tools — allow without prompting
    "mcp-atlassian_jira_get_*": "allow",
    "mcp-atlassian_jira_search*": "allow",
    "mcp-atlassian_jira_batch_get_changelogs": "allow"
{{- end }}
  },

  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@3.0.3",
    "opencode-antigravity-auth"
  ],

  "mcp": {
{{- $servers := index . "mcpServers" -}}
{{- $isPrivate := and (hasKey . "private") .private -}}
{{- $first := true -}}
{{- range $server := $servers -}}
{{- $isPrivateBlocked := and (hasKey $server "conditions") (index $server.conditions "requirePrivateFalse") $isPrivate -}}
{{- if and $server.targets.opencode (not $isPrivateBlocked) -}}
{{- if $first }}{{- $first = false }}{{ else }},{{ end }}
    "{{ $server.id }}": {
{{- if hasKey $server "local" }}
{{- $openCodeCommand := $server.local.command -}}
{{- if and (hasKey $server.local "appendVaultPath") $server.local.appendVaultPath -}}
{{- $openCodeCommand = append $openCodeCommand (printf "%s/Documents/Obsidian/Vault" $.chezmoi.homeDir) -}}
{{- end -}}
      "type": "local",
      "command": {{ $openCodeCommand | toPrettyJson "      " }},
{{- else if hasKey $server "remote" }}
      "type": "remote",
      "url": "{{ $server.remote.url }}",
{{- end }}
      "enabled": {{ $server.enabled | toPrettyJson }}
    }
{{- end -}}
{{- end }}
  }
}
