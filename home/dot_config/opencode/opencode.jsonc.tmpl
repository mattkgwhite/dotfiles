{
  "$schema": "https://opencode.ai/config.json",
  // User preferences (override in project opencode.json if needed)
  "autoupdate": true,

  // GitHub Copilot: run /connect and select "GitHub Copilot", then sign in at github.com/login/device
  "model": "github-copilot/claude-sonnet-4.6",

  "permission": {
    // Require approval before running any shell command (with specific exceptions)
    "bash": {
      "*": "ask",
      // Chezmoi
      "chezmoi apply": "allow",
      "chezmoi apply *": "allow",
      // Shell and environment inspection
      "echo": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "type *": "allow",
      "command -v *": "allow",
      "uname": "allow",
      "uname *": "allow",
      "env": "allow",
      "printenv": "allow",
      "printenv *": "allow",
      "locale": "allow",
      "locale *": "allow",
      "id": "allow",
      "whoami": "allow",
      "groups": "allow",
      "date": "allow",
      "date *": "allow",
      // File and text inspection
      "ls": "allow",
      "ls *": "allow",
      "find *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "du *": "allow",
      "du -s *": "allow",
      "du -h *": "allow",
      "wc *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "egrep *": "allow",
      "fgrep *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "jq *": "allow",
      "column *": "allow",
      "nl *": "allow",
      "base64 *": "allow",
      "xxd *": "allow",
      "strings *": "allow",
      "md5sum *": "allow",
      "sha1sum *": "allow",
      "sha256sum *": "allow",
      "shasum *": "allow",
      "cksum *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      // System and process inspection
      "ps": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      "df": "allow",
      "df *": "allow",
      "uptime": "allow",
      "uptime *": "allow",
      "lsof *": "allow",
      // Git inspection
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git remote -v": "allow",
      "git remote show *": "allow",
      "git rev-parse *": "allow",
      "git describe *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git grep *": "allow",
      "git blame *": "allow",
      // Network inspection
      "ping *": "allow",
      "nslookup *": "allow",
      "dig *": "allow",
      "host *": "allow",
      "netstat": "allow",
      "netstat *": "allow",
      "ifconfig": "allow",
      "ifconfig *": "allow",
      // Kubernetes and containers
      "kubectl config get-contexts": "allow",
      "kubectl config current-context": "allow",
      "kubectl get *": "allow",
      "docker ps": "allow",
      "docker ps *": "allow",
      "docker images": "allow",
      "docker images *": "allow"
    },

    // Allow reads and edits to the chezmoi source tree (global memory lives there)
    "external_directory": {
      "~/.local/share/chezmoi/**": "allow"
    }
{{- if not .private }},

    // Require approval before any Atlassian MCP tool is invoked
    "atlassian_*": "ask",

    // Require approval before any sooperset/mcp-atlassian tool is invoked
    "mcp-atlassian_*": "ask",

    // Read-only Atlassian tools (only read:* scopes) — allow without prompting
    "atlassian_get*": "allow",
    "atlassian_search*": "allow",
    // Outliers with read-only scopes that don't match above patterns
    "atlassian_atlassianUserInfo": "allow",
    "atlassian_fetch": "allow",
    "atlassian_lookupJiraAccountId": "allow",

    // Read-only mcp-atlassian (sooperset) tools — allow without prompting
    "mcp-atlassian_jira_get_*": "allow",
    "mcp-atlassian_jira_search*": "allow",
    "mcp-atlassian_jira_batch_get_changelogs": "allow"
{{- end }}
  },

  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@3.0.3",
    "opencode-antigravity-auth"
  ],

  "mcp": {
{{- if not .private }}
    // Atlassian Rovo MCP server — connects Jira, Confluence, and Compass
    // Auth: run `opencode mcp auth atlassian` to complete the OAuth 2.1 flow
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },

    // sooperset/mcp-atlassian — full Jira tool suite including issue linking
    // Credentials sourced from ~/.config/opencode/mcp-atlassian.env at launch
    "mcp-atlassian": {
      "type": "local",
      "command": ["bash", "-c", "set -a; source ~/.config/opencode/mcp-atlassian.env; set +a; exec mise x python -- uvx mcp-atlassian"],
      "enabled": true
    },
{{- end }}

    // mcp-obsidian — gives OpenCode access to your Obsidian vault
    // https://mcp-obsidian.org
    "obsidian": {
      "type": "local",
      "command": ["mise", "x", "node", "--", "npx", "-y", "@mauricio.wolff/mcp-obsidian@latest", "{{ .chezmoi.homeDir }}/Documents/Obsidian/Vault"],
      "enabled": true
    },

    // Chrome DevTools MCP — browser automation and debugging
    "chrome-devtools": {
      "type": "local",
      "command": ["mise", "x", "node", "--", "npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },

    // Context7 MCP — up-to-date library docs injected into prompts
    // https://context7.com | package: @upstash/context7-mcp
    // Optional: set CONTEXT7_API_KEY for higher rate limits
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },

    // grep.app MCP (Vercel) — search a million public GitHub repos
    // https://vercel.com/blog/grep-a-million-github-repositories-via-mcp
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  }
}
