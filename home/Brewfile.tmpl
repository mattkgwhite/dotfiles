# Brewfile — managed by chezmoi
# Generated from `home/.chezmoidata/brew/*.yaml` overlays.
# Do not edit this file directly; edit the overlay YAML data.
#
# Model:
# - package objects include type/name plus structured conditions.
# - all overlays in `.chezmoidata/brew/*.yaml` are rendered.
#
# - This file is evaluated as Ruby; use OS.mac? / OS.linux? for platform-specific entries.
# - Do NOT regenerate this file wholesale from `brew bundle dump`.
# - Commented-out lines are intentionally excluded (broken, unwanted, or deferred).

{{- $sections := dict "tap" (list) "brew" (list) "cask" (list) "mas" (list) -}}
{{- $seen := dict -}}

{{- if hasKey $.brew "overlays" -}}
{{- range $overlayName := (keys $.brew.overlays | sortAlpha) -}}
    {{- $overlay := index $.brew.overlays $overlayName -}}
    {{- range $pkg := $overlay.packages -}}
      {{- $conditionsIf := list -}}
      {{- $conditionsUnless := list -}}
      {{- if and (hasKey $pkg "conditions") $pkg.conditions -}}
        {{- range $cond := $pkg.conditions -}}
          {{- if and (eq $cond.kind "os") (eq $cond.op "is") -}}
            {{- if eq $cond.value "mac" -}}{{- $conditionsIf = append $conditionsIf "OS.mac?" -}}{{- end -}}
            {{- if eq $cond.value "linux" -}}{{- $conditionsIf = append $conditionsIf "OS.linux?" -}}{{- end -}}
          {{- end -}}
          {{- if eq $cond.kind "env" -}}
            {{- $envName := $cond.name -}}
            {{- if not (hasPrefix $envName "HOMEBREW_") -}}{{- $envName = printf "HOMEBREW_%s" $envName -}}{{- end -}}
            {{- if eq $cond.op "set" -}}{{- $conditionsIf = append $conditionsIf (printf "ENV[%q]" $envName) -}}{{- end -}}
            {{- if eq $cond.op "unset" -}}{{- $conditionsUnless = append $conditionsUnless (printf "ENV[%q]" $envName) -}}{{- end -}}
            {{- if eq $cond.op "equals" -}}{{- $conditionsIf = append $conditionsIf (printf "ENV[%q] == %q" $envName $cond.value) -}}{{- end -}}
            {{- if eq $cond.op "notEquals" -}}{{- $conditionsIf = append $conditionsIf (printf "ENV[%q] != %q" $envName $cond.value) -}}{{- end -}}
          {{- end -}}
          {{- if and (eq $cond.kind "tty") (eq $cond.op "is") -}}
            {{- if $cond.value -}}{{- $conditionsIf = append $conditionsIf "$stdin.tty?" -}}{{- else -}}{{- $conditionsUnless = append $conditionsUnless "$stdin.tty?" -}}{{- end -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}

      {{- $line := "" -}}
      {{- if eq $pkg.type "mas" -}}
        {{- $line = printf "mas %q, id: %v" $pkg.name $pkg.masId -}}
      {{- else -}}
        {{- $line = printf "%s %q" $pkg.type $pkg.name -}}
      {{- end -}}

      {{- if and (gt (len $conditionsIf) 0) (gt (len $conditionsUnless) 0) -}}
        {{- $line = printf "%s if (%s) && !(%s)" $line (join " && " $conditionsIf) (join " || " $conditionsUnless) -}}
      {{- else if gt (len $conditionsIf) 0 -}}
        {{- $line = printf "%s if %s" $line (join " && " $conditionsIf) -}}
      {{- else if gt (len $conditionsUnless) 0 -}}
        {{- $line = printf "%s unless %s" $line (join " || " $conditionsUnless) -}}
      {{- end -}}

      {{- if not (hasKey $seen $line) -}}
        {{- $_ := set $seen $line true -}}
        {{- $sectionLines := index $sections $pkg.type -}}
        {{- $_ = set $sections $pkg.type (append $sectionLines $line) -}}
      {{- end -}}
    {{- end -}}
{{- end -}}
{{- end -}}

{{- range $line := sortAlpha (index $sections "tap") }}
{{ $line }}
{{- end }}
{{- range $line := sortAlpha (index $sections "brew") }}
{{ $line }}
{{- end }}
{{- range $line := sortAlpha (index $sections "cask") }}
{{ $line }}
{{- end }}
{{- range $line := sortAlpha (index $sections "mas") }}
{{ $line }}
{{- end }}
