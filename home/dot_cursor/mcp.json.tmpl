{
  "mcpServers": {
{{- $servers := index . "mcpServers" -}}
{{- $first := true -}}
{{- range $server := $servers -}}
{{- $conditionsMatch := true -}}
{{- if hasKey $server "conditions" -}}
{{- range $conditionKey, $expected := $server.conditions -}}
{{- if and (hasKey $ $conditionKey) (eq (index $ $conditionKey) $expected) -}}
{{- else -}}
{{- $conditionsMatch = false -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{- $cursorEnabled := true -}}
{{- if hasKey $server.targets.cursor "enabled" -}}
{{- $cursorEnabled = $server.targets.cursor.enabled -}}
{{- end -}}
{{- if and $cursorEnabled $conditionsMatch -}}
{{- if hasKey $server "local" -}}
{{- $cursorCommand := $server.local.command -}}
{{- $cursorArgs := list -}}
{{- range $arg := $server.local.args -}}
{{- $resolvedArg := $arg -}}
{{- if hasPrefix $arg "$data." -}}
{{- $dataKey := trimPrefix "$data." $arg -}}
{{- if hasKey $ $dataKey -}}
{{- $resolvedArg = (index $ $dataKey) -}}
{{- end -}}
{{- end -}}
{{- $cursorArgs = append $cursorArgs $resolvedArg -}}
{{- end -}}
{{- $cursorEnv := (default (dict) $server.local.env) -}}
{{- if $first }}{{- $first = false }}{{ else }},{{ end }}
    "{{ $server.id }}": {
      "command": "{{ $cursorCommand }}",
      "env": {{ $cursorEnv | toPrettyJson "      " }},
      "args": {{ $cursorArgs | toPrettyJson "      " }}
    }
{{- else if hasKey $server "remote" -}}
{{- $cursorTransport := "streamableHttp" -}}
{{- if hasKey $server.remote "transport" -}}
{{- $cursorTransport = $server.remote.transport -}}
{{- end -}}
{{- $cursorHeaders := dict -}}
{{- if hasKey $server.remote "headers" -}}
{{- $cursorHeaders = $server.remote.headers -}}
{{- end -}}
{{- if $first }}{{- $first = false }}{{ else }},{{ end }}
    "{{ $server.id }}": {
      "transport": "{{ $cursorTransport }}",
      "url": "{{ $server.remote.url }}",
      "headers": {{ $cursorHeaders | toPrettyJson "      " }}
    }
{{- end -}}
{{- end -}}
{{- end }}
  }
}
