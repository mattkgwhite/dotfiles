{
  // markdownlint-cli2 configuration
  // See: https://github.com/DavidAnson/markdownlint-cli2#configuration
  "config": {
    "extends": ".markdownlint.yml"
  },
  "ignores": [
    // CHANGELOG.md is auto-generated by release-please:
    // - double blank lines between sections (MD012)
    // - duplicate version headings across releases (MD024)
    "CHANGELOG.md"
  ]
}
